<%- include('../partials/Head') %> 
<link rel="stylesheet" href="/output.css">
</head>

<body class="min-h-screen flex flex-col text-white bg-gradient-to-br from-[#ff0080] via-[#7928ca] to-[#2afadf]">

  <%- include('../partials/nav') %>

  <!-- Background Glow -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10">
    <div class="absolute w-[400px] h-[400px] bg-pink-300"></div>
  </div>

  <!-- Container -->
  <div class="flex items-center justify-center flex-grow px-4">

    <!-- Card -->
    <div class="backdrop-blur-xl bg-white/70 shadow-2xl rounded-3xl p-10 w-full max-w-lg border border-white/40">

      <h1 class="text-4xl font-extrabold mb-8 text-center bg-gradient-to-r from-pink-500 to-rose-400 bg-clip-text ">
        Register your Home 🏡
      </h1>

      <!-- Form -->
      <form action="/host/add-home" method="POST" class="space-y-6">

        <!-- Input Group -->
        <div class="space-y-1">
          <label class="text-sm font-medium text-gray-600">House Name</label>
          <input 
            type="text" 
            name="housename" 
            placeholder="Enter your house name"
            class="w-full"
          />
        </div>

        <div class="space-y-1">
          <label class="text-sm font-medium text-gray-600">Price per Night (₹)</label>
          <input 
            type="number" 
            name="price" 
            placeholder="e.g. 2499"
            class="w-full px-4"
          />
        </div>

        <div class="space-y-1">
          <label class="text-sm font-medium text-gray-600">Location</label>
          <input 
            type="text" 
            name="location" 
            placeholder="Enter location"
            class="w-full "
          />
        </div>

        <div class="space-y-1">
          <label class="text-sm font-medium text-gray-600">Rating</label>
          <input 
            type="number" 
            step="0.1"
            name="rating" 
            placeholder="e.g. 4.5"
            class="w-full "
          />
        </div>

        <!-- Button -->
        <button 
          type="submit"
          class="w-full py-3 rounded-xl font-semibold text-black bg-gradient-to-r from-pink-500 to-rose-500 hover:scale-105 hover:shadow-xl transition duration-300"
        >
          Add Home 🚀
        </button>

      </form>

    </div>

  </div>

</body>
</html>