<%- include('../partials/Head') %> 

</head>

<body class="bg-gray-50 text-gray-800">

  <%- include('../partials/nav') %>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-r from-rose-500 via-pink-500 to-red-500 text-white py-16 text-center overflow-hidden">
    <div class="absolute inset-0 bg-black/10 backdrop-blur-sm"></div>
    
    <div class="relative z-10">
      <h1 class="text-5xl font-extrabold tracking-tight">Find your next stay</h1>
      <p class="mt-3 text-lg opacity-90">Discover homes, experiences, and more</p>

      <!-- Search Bar -->
      <div class="mt-6 flex justify-center">
        <input 
          type="text" 
          placeholder="Search destinations..." 
          class="w-80 px-4 py-2 rounded-l-full text-black focus:outline-none"
        />
        <button class="bg-black px-5 py-2 rounded-r-full hover:bg-gray-800 transition">
          Search
        </button>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-3xl font-bold">Explore Homes</h2>
      <span class="text-sm text-gray-500">stays available</span>
    </div>

    <!-- Grid -->
    <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

     

        <li class="group bg-white rounded-3xl shadow-md hover:shadow-2xl transition duration-300 overflow-hidden">

          <!-- Image -->
          <div class="relative h-52 bg-gray-300 overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center text-gray-500">
              Image
            </div>

            <!-- Badge -->
            <span class="absolute top-3 left-3 bg-white text-xs font-semibold px-3 py-1 rounded-full shadow">
              Guest Favorite
            </span>
          </div>

          <!-- Content -->
          <div class="p-5">

            <!-- Title -->
            <h3 class="text-xl font-semibold group-hover:text-pink-500 transition">
            
            </h3>

            <!-- Location -->
            <p class="text-sm text-gray-500 mt-1">
              <India • Cozy stay>
            </p>

            <!-- Rating + Price -->
            <div class="flex justify-between items-center mt-4">
              <span class="text-yellow-500 text-sm">⭐ 4.8</span>
              <span class="font-bold text-gray-800">₹2,499 / night</span>
            </div>

            <!-- Button -->
            <button class="mt-5 w-full bg-gradient-to-r from-pink-500 to-red-500 text-white py-2 rounded-xl font-medium hover:scale-105 hover:shadow-lg transition">
              View Details
            </button>

          </div>

        </li>

  

    </ul>

  </main>

</body>
</html>